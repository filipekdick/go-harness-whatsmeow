# PostgreSQL used by both business data and WhatsMeow sessions.
DATABASE_URL=postgres://harness:harness@127.0.0.1:5432/harness?sslmode=disable

# Recommended MVP path: one OpenRouter key can route to different providers.
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
# Choose a model that advertises tool support:
# https://openrouter.ai/models?supported_parameters=tools
LLM_MODEL=google/gemini-3-flash-preview

# Optional OpenRouter app attribution headers.
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=go-harness-whatsmeow

# Direct Anthropic remains available as an alternative:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-opus-4-8

LLM_MAX_TOKENS=4096
LLM_MAX_ATTEMPTS=3
MAX_TOOL_ITERATIONS=6
HISTORY_TAIL_LIMIT=30
SUMMARIZE_AFTER=50
WORKER_COUNT=4
WORKER_QUEUE_SIZE=128
